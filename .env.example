DATABASE_URI=postgresql://postgres:postgres@localhost:5432/portal_stack
PAYLOAD_SECRET=replace-me-with-a-long-random-string
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NODE_ENV=development

# Tenant configuration
TENANT_ID=core
NEXT_PUBLIC_TENANT_ID=core

# AI agent (optional - leave empty to disable)
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Auth provider: "local" (default) or "agentyx" (future)
AUTH_PROVIDER=local
# AGENTYX_JWKS_URL=
# AGENTYX_AUDIENCE=

# Email (Resend)
# If RESEND_API_KEY is empty, emails are logged to console (dev mode).
RESEND_API_KEY=
EMAIL_FROM=no-reply@portal.local
EMAIL_FROM_NAME=Portal Stack
