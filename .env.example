# ── Local dev (docker compose up -d) ─────────────────────────────────────
# Railway prod: ver docs/RAILWAY.md — DATABASE_URI=${{Postgres.DATABASE_URL}}
DATABASE_URI=postgresql://postgres:postgres@localhost:5432/portal_stack
PAYLOAD_SECRET=replace-me-with-a-long-random-string
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NODE_ENV=development

# Tenant configuration (Railway: un servicio = un TENANT_ID)
TENANT_ID=core
NEXT_PUBLIC_TENANT_ID=core

# AI agent (optional - leave empty to disable)
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# AI backend: "local" (AI SDK in Next.js) or "fastapi" (proxy to external agent)
AI_BACKEND=local
# External FastAPI agent (required when ai.backend=fastapi) — ver docs/API_INTEGRATION.md
FASTAPI_AGENT_URL=
FASTAPI_AGENT_SECRET=
# FASTAPI_AGENT_TIMEOUT_MS=30000
# ponytail: opt-in only — silently falls back to local AI SDK when FastAPI is unreachable
# AI_BACKEND_FALLBACK=local

# Auth provider: "local" (default) or "agentyx" (future)
AUTH_PROVIDER=local
# Override when tenants/<id>/config.ts uses a non-default auth.cookieName (middleware reads this at edge)
# AUTH_COOKIE_NAME=payload-token
# AGENTYX_JWKS_URL=
# AGENTYX_AUDIENCE=

# Email (Resend)
# If RESEND_API_KEY is empty, emails are logged to console (dev mode).
RESEND_API_KEY=
EMAIL_FROM=no-reply@portal.local
EMAIL_FROM_NAME=Portal Stack

# Integrations (secrets per tenant — never commit real values)
WEBHOOK_SECRET=
# INTEGRATION_CORE_QUICKBASE_TOKEN=
# QUICKBASE_REALM=yourrealm.quickbase.com
# QUICKBASE_PROJECTS_TABLE=
# QUICKBASE_CONTRACTS_TABLE=
# INTEGRATION_CORE_HUBSPOT_TOKEN=
# DATASET_HTTP_TIMEOUT_MS=15000

# Redis (optional — not used by portal-stack today; Railway plugin when needed)
# REDIS_URL=redis://localhost:6379
# Railway: REDIS_URL=${{Redis.REDIS_URL}}

# Media storage (roadmap: S3 / Vercel Blob — today local public/media)
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# RAG over documents (not implemented — flag for future)
# FEATURE_RAG=false
